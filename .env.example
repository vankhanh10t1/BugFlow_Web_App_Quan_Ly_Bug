DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DB?sslmode=verify-full"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=verify-full"

AUTH_SECRET=""
# Chỉ dùng localhost trong .env.local. Trên Vercel, hãy bỏ AUTH_URL để Auth.js
# nhận host hiện tại từ Vercel, hoặc đặt đúng domain production (không dùng localhost).
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Public Web SDK key used by the client-side GIPHY GIF picker.
NEXT_PUBLIC_GIPHY_API_KEY=""
# Comma-separated additional trusted browser origins. Leave empty for same-origin only.
ALLOWED_ORIGINS=""

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TWO_FACTOR_ENCRYPTION_KEY=""
TWO_FACTOR_CHALLENGE_TTL_MINUTES="10"
TWO_FACTOR_MAX_ATTEMPTS="5"
TWO_FACTOR_TOTP_WINDOW="2"

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
UPLOAD_MAX_SIZE_MB="10"
BUG_ATTACHMENT_MAX_FILES="5"
AVATAR_MAX_SIZE_MB="5"

# Protects /api/cron/deadline-notifications. Use a long random value in Vercel.
CRON_SECRET=""

# GroqCloud AI Chatbot (server-side only).
GROQ_API_KEY=""
GROQ_DEFAULT_MODEL="llama-3.1-8b-instant"
GROQ_REASONING_MODEL="openai/gpt-oss-120b"
AI_MAX_INPUT_TOKENS="4000"
AI_DAILY_USER_LIMIT="50"
AI_REQUEST_TIMEOUT_MS="30000"
AI_DATA_REGION=""
