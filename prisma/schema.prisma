generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  ADMIN
  PROJECT_MANAGER
  TESTER
  DEVELOPER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ProjectRole {
  MANAGER
  TESTER
  DEVELOPER
  VIEWER
}

enum BugStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  READY_FOR_TEST
  REOPENED
  CLOSED
  REJECTED
  DUPLICATE
}

enum BugPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BugSeverity {
  MINOR
  MAJOR
  CRITICAL
  BLOCKER
}

enum ActivityType {
  BUG_CREATED
  BUG_UPDATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  SEVERITY_CHANGED
  ASSIGNEE_CHANGED
  COMMENT_ADDED
  COMMENT_UPDATED
  COMMENT_DELETED
  ATTACHMENT_ADDED
  ATTACHMENT_DELETED
  MEMBER_ADDED
  MEMBER_REMOVED
  PROJECT_UPDATED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  TWO_FACTOR_RECOVERY_CODES_REGENERATED
  TWO_FACTOR_RESET_BY_ADMIN
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  TWO_FACTOR_VERIFICATION_FAILED
  TWO_FACTOR_RECOVERY_CODE_USED
}

enum NotificationType {
  BUG_ASSIGNED
  BUG_UPDATED
  STATUS_CHANGED
  COMMENT_ADDED
  MENTIONED
  PROJECT_MEMBER_ADDED
  BUG_DEADLINE_SOON
  DUE_DATE_APPROACHING
  BUG_OVERDUE
  CHAT_MESSAGE
}

enum ChatConversationType {
  PROJECT
  DIRECT
  SUPPORT
}

enum ChatMessageType {
  TEXT
  EMOJI
  STICKER
  GIF
  IMAGE
  FILE
  REMINDER
}

enum ChatMessagePriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum AttachmentType {
  IMAGE
  VIDEO
  LOG
  TEXT
  PDF
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  passwordHash             String
  fullName                 String
  username                 String                    @unique
  avatarUrl                String?
  avatarPublicId           String?
  systemRole               SystemRole                @default(TESTER)
  accountStatus            AccountStatus             @default(ACTIVE)
  lastLoginAt              DateTime?
  twoFactorEnabled         Boolean                   @default(false)
  twoFactorSecretEncrypted String?
  twoFactorEnabledAt       DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  projectsCreated          Project[]                 @relation("ProjectCreator")
  projectMemberships       ProjectMember[]
  bugsReported             Bug[]                     @relation("BugReporter")
  bugsAssigned             Bug[]                     @relation("BugAssignee")
  bugsTested               Bug[]                     @relation("BugTester")
  comments                 Comment[]
  attachments              Attachment[]
  activities               ActivityLog[]
  notifications            Notification[]            @relation("NotificationRecipient")
  notificationsCreated     Notification[]            @relation("NotificationActor")
  accounts                 Account[]
  sessions                 Session[]
  twoFactorRecoveryCodes   TwoFactorRecoveryCode[]
  twoFactorLoginChallenges TwoFactorLoginChallenge[]
  chatConversationsCreated ChatConversation[]        @relation("ChatConversationCreator")
  chatParticipants         ChatParticipant[]
  chatMessages             ChatMessage[]
  chatMessagesPinned       ChatMessage[]             @relation("ChatMessagePinnedBy")
  chatMessageMarks         ChatMessageMark[]
  chatMessagesHidden       ChatMessageHidden[]
  chatMessageReactions     ChatMessageReaction[]
  chatReports              ChatReport[]

  @@index([systemRole])
  @@index([accountStatus])
  @@index([createdAt])
}

model Project {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  description      String?
  status           ProjectStatus     @default(PLANNING)
  startDate        DateTime?
  expectedEndDate  DateTime?
  nextBugNumber    Int               @default(1)
  createdById      String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        User              @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members          ProjectMember[]
  bugs             Bug[]
  activities       ActivityLog[]
  notifications    Notification[]
  chatConversation ChatConversation?

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
}

model Bug {
  id                 String         @id @default(cuid())
  bugCode            String         @unique
  sequenceNumber     Int
  projectId          String
  title              String
  description        String
  reproductionSteps  String?
  expectedResult     String?
  actualResult       String?
  environment        String?
  browser            String?
  operatingSystem    String?
  applicationVersion String?
  status             BugStatus      @default(NEW)
  priority           BugPriority    @default(MEDIUM)
  severity           BugSeverity    @default(MAJOR)
  reporterId         String
  assigneeId         String?
  testerId           String?
  dueDate            DateTime?
  resolvedAt         DateTime?
  closedAt           DateTime?
  deletedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  project            Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  reporter           User           @relation("BugReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  assignee           User?          @relation("BugAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  tester             User?          @relation("BugTester", fields: [testerId], references: [id], onDelete: SetNull)
  comments           Comment[]
  attachments        Attachment[]
  activities         ActivityLog[]
  notifications      Notification[]

  @@unique([projectId, sequenceNumber])
  @@index([projectId, status])
  @@index([priority])
  @@index([severity])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([dueDate])
  @@index([createdAt])
  @@index([deletedAt])
}

model Comment {
  id          String       @id @default(cuid())
  bugId       String
  authorId    String
  content     String
  isEdited    Boolean      @default(false)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bug         Bug          @relation(fields: [bugId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id], onDelete: Restrict)
  attachments Attachment[]

  @@index([bugId, createdAt])
  @@index([authorId])
  @@index([deletedAt])
}

model Attachment {
  id               String         @id @default(cuid())
  originalFileName String
  publicId         String         @unique
  fileUrl          String
  mimeType         String
  fileSize         Int
  type             AttachmentType
  uploadedById     String
  bugId            String?
  commentId        String?
  createdAt        DateTime       @default(now())
  uploadedBy       User           @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  bug              Bug?           @relation(fields: [bugId], references: [id], onDelete: Cascade)
  comment          Comment?       @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([bugId])
  @@index([commentId])
  @@index([uploadedById])
}

model ActivityLog {
  id          String       @id @default(cuid())
  projectId   String?
  bugId       String?
  actorId     String
  actionType  ActivityType
  fieldName   String?
  oldValue    String?
  newValue    String?
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bug         Bug?         @relation(fields: [bugId], references: [id], onDelete: Cascade)
  actor       User         @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@index([bugId, createdAt])
  @@index([actorId])
  @@index([actionType])
}

model TwoFactorRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model TwoFactorLoginChallenge {
  id             String    @id @default(cuid())
  userId         String
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  failedAttempts Int       @default(0)
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, usedAt])
}

model Notification {
  id             String            @id @default(cuid())
  recipientId    String
  actorId        String?
  bugId          String?
  projectId      String?
  conversationId String?
  chatMessageId  String?
  dedupeKey      String?           @unique
  type           NotificationType
  title          String
  message        String
  isRead         Boolean           @default(false)
  readAt         DateTime?
  createdAt      DateTime          @default(now())
  recipient      User              @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor          User?             @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  bug            Bug?              @relation(fields: [bugId], references: [id], onDelete: Cascade)
  project        Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation   ChatConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  chatMessage    ChatMessage?      @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt])
  @@index([bugId])
  @@index([projectId])
  @@index([conversationId])
  @@index([chatMessageId])
}

model ChatConversation {
  id            String               @id @default(cuid())
  type          ChatConversationType
  title         String?
  projectId     String?              @unique
  directKey     String?              @unique
  createdById   String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  project       Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User                 @relation("ChatConversationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  participants  ChatParticipant[]
  messages      ChatMessage[]
  notifications Notification[]
  reports       ChatReport[]

  @@index([type, updatedAt])
  @@index([createdById])
}

model ChatParticipant {
  id             String           @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime         @default(now())
  leftAt         DateTime?
  lastReadAt     DateTime?
  lastDeliveredAt DateTime?
  hiddenAt        DateTime?
  historyClearedAt DateTime?
  autoDeleteSeconds Int?
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, leftAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  senderId       String
  clientId       String?
  content        String
  type           ChatMessageType     @default(TEXT)
  priority       ChatMessagePriority @default(NORMAL)
  sticker        String?
  gifUrl         String?
  gifPreviewUrl  String?
  gifWidth       Int?
  gifHeight      Int?
  gifProvider    String?
  attachmentUrl  String?
  attachmentPublicId String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?
  attachmentType AttachmentType?
  reminderAt     DateTime?
  pinnedAt       DateTime?
  pinnedById     String?
  recalledAt     DateTime?
  recalledById   String?
  createdAt      DateTime         @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation(fields: [senderId], references: [id], onDelete: Restrict)
  pinnedBy       User?            @relation("ChatMessagePinnedBy", fields: [pinnedById], references: [id], onDelete: SetNull)
  notifications  Notification[]
  marks          ChatMessageMark[]
  hiddenFor      ChatMessageHidden[]
  reactions      ChatMessageReaction[]

  @@unique([conversationId, clientId])
  @@index([conversationId, createdAt, id])
  @@index([senderId])
  @@index([conversationId, pinnedAt])
  @@index([conversationId, type, createdAt])
  @@index([reminderAt])
}

model ChatMessageMark {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
}

model ChatMessageHidden {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
}

model ChatMessageReaction {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model ChatReport {
  id             String           @id @default(cuid())
  conversationId String
  reporterId     String
  reason         String
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reporter       User             @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([reporterId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RateLimitBucket {
  id          String   @id
  scope       String
  count       Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
  @@index([scope, expiresAt])
}
